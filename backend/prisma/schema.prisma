
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

//creating the models now
model User {
  id      String  @id @default(cuid())
  name   String   @unique
  createdAt    DateTime  @default(now())

history ExcuseHistory[]
}

model Excuse {
  id        String   @id @default(cuid())
  text      String
  tier      Int
  source    Source   @default(STATIC)
  createdAt DateTime @default(now())

  history ExcuseHistory[]
}

model ExcuseHistory{
  id  String @id @default(cuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  excuse   Excuse @relation(fields: [excuseId], references: [id])
  excuseId String
}

enum Source {
  STATIC
  AI
}
